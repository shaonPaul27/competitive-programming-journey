Problem A: Iskander and Drawings
Sol:
#include <bits/stdc++.h>
#define MaxThree(a,b,c) max(a,max(b,c)) //finding max between 3 numbers
#define MinThree(a,b,c) min(a,min(b,c)) //finding min between 3 numbers
#define debug(x) cout<<#x<<": "<<x<<endl
#define DEBUG(x) cout<<#x<<": "<<x<<endl
#define ll long long
#define LL long long
using namespace std;
void solve(){
    int n; cin>>n;
    string s = "#*##*##";
    cin>>s;

    int cnt = 0, mx = -1;
    for(int i=0; i<s.size(); i++){
        if(s[i] == '#')cnt++;
        else{
            mx = max(mx, cnt);
            cnt = 0;
        }
    }
    mx = max(mx, cnt);
//    debug(mx);
    if(mx%2 == 0)cout<<mx/2;
    else cout<<(mx/2)+1;
}
int main(){
    ll testCase = 1;
    cin>>testCase;
    for(ll test = 1; test<= testCase; test++){
        solve();
        cout<<"\n";
    }
    return 0;
}
